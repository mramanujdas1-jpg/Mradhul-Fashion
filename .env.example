# =========================================================================
#                     Mradhul Fashion Platform - Env Configuration
# =========================================================================

# ----------------- BACKEND API (.env in ./backend) -----------------
PORT=5000
MONGO_URI=mongodb://localhost:27017/mradhul_fashion
JWT_SECRET=super_secret_jwt_token_for_mradhul_fashion
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ----------------- FRONTEND NEXT.JS WEB APP (.env in ./web) -----------------
# Tells Next.js how to reach the Express backend server
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ----------------- MOBILE EXPO APP (.env in ./mobile) -----------------
# For Android Emulator access, use http://10.0.2.2:5000/api
# For iOS Emulator or local physical device, use your machine's local IP (e.g., http://192.168.1.XX:5000/api)
EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api
